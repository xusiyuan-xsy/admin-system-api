<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.DatingPackageMapper">

    <resultMap type="DatingPackage" id="DatingPackageResult">
        <id     property="packageId"         column="package_id"          />
        <result property="packageName"        column="package_name"        />
        <result property="packageType"        column="package_type"        />
        <result property="price"              column="price"               />
        <result property="limitExpire"        column="limit_expire"        />
        <result property="serviceDuration"    column="service_duration"    />
        <result property="limitServiceTimes"  column="limit_service_times" />
        <result property="serviceTimes"       column="service_times"       />
        <result property="description"        column="description"         />
        <result property="coverImage"         column="cover_image"         />
        <result property="sortOrder"          column="sort_order"          />
        <result property="status"             column="status"              />
        <result property="createBy"           column="create_by"           />
        <result property="createTime"         column="create_time"         />
        <result property="updateBy"           column="update_by"           />
        <result property="updateTime"         column="update_time"         />
    </resultMap>

    <sql id="selectDatingPackageVo">
        select package_id, package_name, package_type, price,
               limit_expire, service_duration, limit_service_times, service_times,
               description, cover_image, sort_order, status,
               create_by, create_time, update_by, update_time
        from dating_package
    </sql>

    <select id="selectDatingPackageList" parameterType="DatingPackage" resultMap="DatingPackageResult">
        <include refid="selectDatingPackageVo"/>
        <where>
            <if test="packageName != null and packageName != ''">
                and package_name like concat('%', #{packageName}, '%')
            </if>
            <if test="packageType != null and packageType != ''">
                and package_type = #{packageType}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by sort_order asc, create_time desc
    </select>

    <select id="selectDatingPackageById" parameterType="Long" resultMap="DatingPackageResult">
        <include refid="selectDatingPackageVo"/>
        where package_id = #{packageId}
    </select>

    <insert id="insertDatingPackage" parameterType="DatingPackage" useGeneratedKeys="true" keyProperty="packageId">
        insert into dating_package (
            <if test="packageName != null and packageName != ''">package_name,</if>
            <if test="packageType != null and packageType != ''">package_type,</if>
            <if test="price != null">price,</if>
            <if test="limitExpire != null and limitExpire != ''">limit_expire,</if>
            <if test="serviceDuration != null">service_duration,</if>
            <if test="limitServiceTimes != null and limitServiceTimes != ''">limit_service_times,</if>
            <if test="serviceTimes != null">service_times,</if>
            <if test="description != null and description != ''">description,</if>
            <if test="coverImage != null and coverImage != ''">cover_image,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            update_time
        ) values (
            <if test="packageName != null and packageName != ''">#{packageName},</if>
            <if test="packageType != null and packageType != ''">#{packageType},</if>
            <if test="price != null">#{price},</if>
            <if test="limitExpire != null and limitExpire != ''">#{limitExpire},</if>
            <if test="serviceDuration != null">#{serviceDuration},</if>
            <if test="limitServiceTimes != null and limitServiceTimes != ''">#{limitServiceTimes},</if>
            <if test="serviceTimes != null">#{serviceTimes},</if>
            <if test="description != null and description != ''">#{description},</if>
            <if test="coverImage != null and coverImage != ''">#{coverImage},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            sysdate()
        )
    </insert>

    <update id="updateDatingPackage" parameterType="DatingPackage">
        update dating_package
        <set>
            <if test="packageName != null and packageName != ''">package_name = #{packageName},</if>
            <if test="packageType != null and packageType != ''">package_type = #{packageType},</if>
            <if test="price != null">price = #{price},</if>
            <if test="limitExpire != null and limitExpire != ''">limit_expire = #{limitExpire},</if>
            <if test="serviceDuration != null">service_duration = #{serviceDuration},</if>
            <if test="limitServiceTimes != null and limitServiceTimes != ''">limit_service_times = #{limitServiceTimes},</if>
            <if test="serviceTimes != null">service_times = #{serviceTimes},</if>
            <if test="description != null">description = #{description},</if>
            <if test="coverImage != null">cover_image = #{coverImage},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where package_id = #{packageId}
    </update>

    <delete id="deleteDatingPackageById" parameterType="Long">
        delete from dating_package where package_id = #{packageId}
    </delete>

    <delete id="deleteDatingPackageByIds" parameterType="Long">
        delete from dating_package where package_id in
        <foreach collection="array" item="packageId" open="(" separator="," close=")">
            #{packageId}
        </foreach>
    </delete>

</mapper>
