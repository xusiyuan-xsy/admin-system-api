<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysPayingUserMapper">

    <resultMap type="SysPayingUser" id="SysPayingUserResult">
        <id     property="id"             column="id"              />
        <result property="phone"          column="phone"           />
        <result property="password"       column="password"        />
        <result property="lastLoginIp"    column="last_login_ip"   />
        <result property="lastLoginTime"  column="last_login_time" />
        <result property="name"           column="name"            />
        <result property="sex"            column="sex"             />
        <result property="birthYear"      column="birth_year"      />
        <result property="zodiac"         column="zodiac"          />
        <result property="height"         column="height"          />
        <result property="weight"         column="weight"          />
        <result property="hometown"       column="hometown"        />
        <result property="currentCity"    column="current_city"    />
        <result property="education"      column="education"       />
        <result property="occupation"     column="occupation"      />
        <result property="monthlyIncome"  column="monthly_income"  />
        <result property="familyMembers"  column="family_members"  />
        <result property="hasCar"         column="has_car"         />
        <result property="hasHouse"       column="has_house"       />
        <result property="houseDesc"      column="house_desc"      />
        <result property="hobbies"        column="hobbies"         />
        <result property="advantages"     column="advantages"      />
        <result property="smokeHabit"     column="smoke_habit"     />
        <result property="drinkHabit"     column="drink_habit"     />
        <result property="hasTattoo"      column="has_tattoo"      />
        <result property="acceptLongDist" column="accept_long_dist"/>
        <result property="photos"         column="photos"          typeHandler="com.ruoyi.framework.handler.JsonStringListTypeHandler"/>
        <result property="status"         column="status"          />
        <result property="delFlag"        column="del_flag"        />
        <result property="remark"         column="remark"          />
        <result property="createBy"       column="create_by"       />
        <result property="createTime"     column="create_time"     />
        <result property="updateBy"       column="update_by"       />
        <result property="updateTime"     column="update_time"     />
        <association property="requirement" javaType="SysPayingRequirement">
            <id     property="id"              column="req_id"               />
            <result property="payingId"        column="req_paying_id"        />
            <result property="ageMin"          column="req_age_min"          />
            <result property="ageMax"          column="req_age_max"          />
            <result property="hometownRequire" column="req_hometown_require" />
            <result property="cityRequire"     column="req_city_require"     />
            <result property="education"       column="req_education"        />
            <result property="heightMin"       column="req_height_min"       />
            <result property="heightMax"       column="req_height_max"       />
            <result property="noTattoo"        column="req_no_tattoo"        />
            <result property="acceptLongDist"  column="req_accept_long_dist" />
            <result property="smokeHabit"      column="req_smoke_habit"      />
            <result property="drinkHabit"      column="req_drink_habit"      />
            <result property="hasCar"          column="req_has_car"          />
            <result property="hasHouse"        column="req_has_house"        />
            <result property="otherRequire"    column="req_other_require"    />
        </association>
    </resultMap>

    <sql id="selectPayingUserVo">
        select u.id, u.phone, u.last_login_ip, u.last_login_time, u.name, u.sex, u.birth_year, u.zodiac,
               u.height, u.weight, u.hometown, u.current_city, u.education, u.occupation, u.monthly_income,
               u.family_members, u.has_car, u.has_house, u.house_desc, u.hobbies, u.advantages,
               u.smoke_habit, u.drink_habit, u.has_tattoo, u.accept_long_dist, u.photos,
               u.status, u.del_flag, u.remark, u.create_by, u.create_time, u.update_by, u.update_time,
               r.id               as req_id,
               r.paying_id        as req_paying_id,
               r.age_min          as req_age_min,
               r.age_max          as req_age_max,
               r.hometown_require as req_hometown_require,
               r.city_require     as req_city_require,
               r.education        as req_education,
               r.height_min       as req_height_min,
               r.height_max       as req_height_max,
               r.no_tattoo        as req_no_tattoo,
               r.accept_long_dist as req_accept_long_dist,
               r.smoke_habit      as req_smoke_habit,
               r.drink_habit      as req_drink_habit,
               r.has_car          as req_has_car,
               r.has_house        as req_has_house,
               r.other_require    as req_other_require
        from sys_paying_user u
        left join sys_paying_requirement r on r.paying_id = u.id
    </sql>

    <select id="selectPayingUserList"  parameterType="SysPayingUser" resultMap="SysPayingUserResult">
        <include refid="selectPayingUserVo"/>
        <where>
            and u.del_flag = '0'
            <if test="phone != null and phone != ''">
                and u.phone like concat('%', #{phone}, '%')
            </if>
            <if test="name != null and name != ''">
                and u.name like concat('%', #{name}, '%')
            </if>
            <if test="currentCity != null and currentCity != ''">
                and u.current_city like concat('%', #{currentCity}, '%')
            </if>
            <if test="status != null and status != ''">
                and u.status = #{status}
            </if>
            <if test="params.beginTime != null and params.beginTime != ''"><!-- ????????? -->
                and date_format(u.create_time,'%Y%m%d') &gt;= date_format(#{params.beginTime},'%Y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''"><!-- ?????????? -->
                and date_format(u.create_time,'%Y%m%d') &lt;= date_format(#{params.endTime},'%Y%m%d')
            </if>
        </where>
    </select>

    <select id="selectPayingUserById" parameterType="Long" resultMap="SysPayingUserResult">
        <include refid="selectPayingUserVo"/>
        where u.id = #{id}
    </select>

    <select id="checkPhoneUnique" parameterType="String" resultMap="SysPayingUserResult">
        <include refid="selectPayingUserVo"/>
        where u.phone = #{phone} and u.del_flag = '0' limit 1
    </select>

    <update id="updatePayingUser" parameterType="SysPayingUser">
        update sys_paying_user
        <set>
            <if test="phone != null and phone != ''">phone = #{phone},</if>
            <if test="password != null and password != ''">password = #{password},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="sex != null and sex != ''">sex = #{sex},</if>
            <if test="birthYear != null">birth_year = #{birthYear},</if>
            <if test="zodiac != null and zodiac != ''">zodiac = #{zodiac},</if>
            <if test="height != null">height = #{height},</if>
            <if test="weight != null">weight = #{weight},</if>
            <if test="hometown != null and hometown != ''">hometown = #{hometown},</if>
            <if test="currentCity != null and currentCity != ''">current_city = #{currentCity},</if>
            <if test="education != null and education != ''">education = #{education},</if>
            <if test="occupation != null and occupation != ''">occupation = #{occupation},</if>
            <if test="monthlyIncome != null">monthly_income = #{monthlyIncome},</if>
            <if test="familyMembers != null and familyMembers != ''">family_members = #{familyMembers},</if>
            <if test="hasCar != null and hasCar != ''">has_car = #{hasCar},</if>
            <if test="hasHouse != null and hasHouse != ''">has_house = #{hasHouse},</if>
            <if test="houseDesc != null and houseDesc != ''">house_desc = #{houseDesc},</if>
            <if test="hobbies != null and hobbies != ''">hobbies = #{hobbies},</if>
            <if test="advantages != null and advantages != ''">advantages = #{advantages},</if>
            <if test="smokeHabit != null and smokeHabit != ''">smoke_habit = #{smokeHabit},</if>
            <if test="drinkHabit != null and drinkHabit != ''">drink_habit = #{drinkHabit},</if>
            <if test="hasTattoo != null and hasTattoo != ''">has_tattoo = #{hasTattoo},</if>
            <if test="acceptLongDist != null and acceptLongDist != ''">accept_long_dist = #{acceptLongDist},</if>
            <if test="photos != null">photos = #{photos, typeHandler=com.ruoyi.framework.handler.JsonStringListTypeHandler},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null and remark != ''">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deletePayingUserByIds" parameterType="Long[]">
        update sys_paying_user set del_flag = '2' where id in
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <insert id="insertPayingUser" parameterType="SysPayingUser" useGeneratedKeys="true" keyProperty="id">
        insert into sys_paying_user (
            <if test="phone != null and phone != ''">phone,</if>
            <if test="password != null and password != ''">password,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="sex != null and sex != ''">sex,</if>
            <if test="birthYear != null">birth_year,</if>
            <if test="zodiac != null and zodiac != ''">zodiac,</if>
            <if test="height != null">height,</if>
            <if test="weight != null">weight,</if>
            <if test="hometown != null and hometown != ''">hometown,</if>
            <if test="currentCity != null and currentCity != ''">current_city,</if>
            <if test="education != null and education != ''">education,</if>
            <if test="occupation != null and occupation != ''">occupation,</if>
